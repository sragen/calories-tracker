# Database
DB_PASSWORD=change_me_strong_password

# JWT — minimum 32 chars, use: openssl rand -hex 32
JWT_SECRET=change_me_to_a_very_long_secret_key_at_least_32_chars

# MinIO object storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret

# Gemini AI (food scan)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Play (IAP validation)
GOOGLE_PLAY_PACKAGE_NAME=com.company.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# App Store (IAP validation)
APP_STORE_BUNDLE_ID=com.company.app
APP_STORE_ISSUER_ID=your_issuer_id
APP_STORE_KEY_ID=your_key_id
APP_STORE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
